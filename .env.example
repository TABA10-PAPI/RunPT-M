# OAuth API Keys
# 카카오 개발자 센터에서 발급받은 API 키
EXPO_PUBLIC_KAKAO_API_KEY=your_kakao_api_key_here
EXPO_PUBLIC_KAKAO_API_KEY_MOBILE=your_kakao_mobile_api_key_here
EXPO_PUBLIC_KAKAO_REDIRECT_URI=your_kakao_redirect_uri_here

# 네이버 개발자 센터에서 발급받은 API 키
EXPO_PUBLIC_NAVER_API_KEY=your_naver_api_key_here
EXPO_PUBLIC_NAVER_SECRET_KEY=your_naver_secret_key_here
EXPO_PUBLIC_NAVER_REDIRECT_URI=your_naver_redirect_uri_here

# API Base URL (선택사항)
# EXPO_PUBLIC_BASE_URL=http://52.78.76.223:8080
