# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
# /android - Android 소스 코드는 커밋 필요 (HealthConnectModule 등)

.idea
.env

# Android build
android/app/build/
android/build/
android/.gradle/
android/.externalNativeBuild/
android/**/.cxx/
android/captures/

# Local configuration
android/local.properties

# Sensitive files with API keys (generated by expo prebuild)
# android/app/src/main/AndroidManifest.xml - AndroidManifest는 커밋 필요
# android/app/src/main/res/values/strings.xml - strings.xml은 커밋 필요 (플러그인이 환경 변수로 키 추가)

# Keystore files
android/app/debug.keystore
android/app/*.keystore
android/app/*.jks

# IDE files
android/.idea/
android/.settings/
android/*.iml
android/**/*.iml

# System files
android/.DS_Store
android/**/.DS_Store
android/Thumbs.db

# Expo / React Native generated
android/app/build/generated/
android/app/build/intermediates/
android/app/build/outputs/

# Logs & temp
android/**/*.log
android/**/*.tmp

